{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/plaza-opinarios",
      "dest": "/public/enviar-opinarios-plaza.html"
    },
    {
      "src": "/operacional/plaza",
      "dest": "/public/dashboard-operacional-plaza.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/",
      "dest": "/public/dashboard-tv.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
